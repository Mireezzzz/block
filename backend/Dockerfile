# =============================================================
# Dockerfile для Flask-бэкенда
# =============================================================

# Базовый образ: официальный Python 3.12, slim = урезанная версия
# без лишних пакетов (меньше размер, быстрее скачивается)
FROM python:3.12-slim

# Устанавливаем рабочую директорию ВНУТРИ контейнера.
# Все следующие команды выполняются из /app
WORKDIR /app
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
# Сначала копируем ТОЛЬКО requirements.txt (не весь код).
# Зачем? Docker кэширует слои. Если код изменился, но зависимости нет —
# Docker не будет переустанавливать пакеты. Это ускоряет пересборку.
COPY . .

# Устанавливаем зависимости.
# --no-cache-dir — не сохранять кэш pip (экономим место в образе)
RUN pip install --no-cache-dir -r requirements.txt

# Теперь копируем весь остальной код бэкенда

# Документируем: контейнер будет слушать порт 5000
# Это НЕ открывает порт — только метаданные. Реальный проброс в docker-compose.
EXPOSE 5000

# Команда запуска при старте контейнера.
# gunicorn — production WSGI-сервер для Flask (надёжнее чем flask run)
# app:app  — файл app.py, объект app внутри него
# -w 2     — 2 worker-процесса (параллельная обработка запросов)
# -b 0.0.0.0:5000 — слушать на всех интерфейсах, порт 5000
CMD ["gunicorn", "app:app", "-w", "2", "-b", "0.0.0.0:5000", "--timeout", "120"]